# ─────────────────────────────────────────
# Environment
# ─────────────────────────────────────────
# Set to "production" for prod, "development" for local dev
NODE_ENV=production

# ─────────────────────────────────────────
# Server
# ─────────────────────────────────────────
# Port the HTTP server listens on
PORT=3000
# Bind address — use 0.0.0.0 to accept all interfaces (required in Docker/Pelican)
HOSTNAME=0.0.0.0

# ─────────────────────────────────────────
# App URL
# ─────────────────────────────────────────
# Full public URL of the app (with protocol, no trailing slash)
APP_URL=https://your-domain.com

# ─────────────────────────────────────────
# Better Auth
# ─────────────────────────────────────────
# Random secret, min 32 chars — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=change-this-to-a-random-32-char-secret
# Must match APP_URL in production
BETTER_AUTH_URL=https://your-domain.com
# Must match BETTER_AUTH_URL (exposed to the browser)
NEXT_PUBLIC_BETTER_AUTH_URL=https://your-domain.com

# ─────────────────────────────────────────
# Discord OAuth
# ─────────────────────────────────────────
# https://discord.com/developers/applications → OAuth2
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# ─────────────────────────────────────────
# GitHub (optional — for higher API rate limits)
# ─────────────────────────────────────────
# https://github.com/settings/tokens/new → generate token with "public_repo" scope
# Without token: 60 requests/hour (may hit rate limits)
# With token: 5000 requests/hour
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────
# Database (Neon PostgreSQL)
# ─────────────────────────────────────────
# Pooled connection — used by the app at runtime (has -pooler in hostname)
DATABASE_URL=postgresql://user:password@endpoint-pooler.region.aws.neon.tech/neondb?sslmode=require
# Direct (non-pooled) — used by Prisma CLI (migrate, push, generate)
DIRECT_URL=postgresql://user:password@endpoint.region.aws.neon.tech/neondb?sslmode=require

# ─────────────────────────────────────────
# SMTP / Email (Spaceship, Gmail, etc.)
# ─────────────────────────────────────────
SMTP_HOST=mail.spacemail.com
SMTP_PORT=465
SMTP_USER=mark@xsaitox.dev
SMTP_PASS=your_password
# Where to receive contact form submissions
CONTACT_EMAIL=mark@xsaitox.dev
