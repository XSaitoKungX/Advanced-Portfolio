# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Bun
bun.lockb

# ─────────────────────────────────────────
# Testing
# ─────────────────────────────────────────
/coverage
.nyc_output
*.lcov

# ─────────────────────────────────────────
# Next.js / Build Output
# ─────────────────────────────────────────
/.next/
/out/
/build
dist/

# ─────────────────────────────────────────
# Environment Files
# ─────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
!.env.example

# ─────────────────────────────────────────
# Vercel / Deployment
# ─────────────────────────────────────────
.vercel
.netlify

# ─────────────────────────────────────────
# Debug Logs
# ─────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs/

# ─────────────────────────────────────────
# IDE / Editor Files
# ─────────────────────────────────────────
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.vimrc.local

# Emacs
*~
.#*

# ─────────────────────────────────────────
# OS Generated Files
# ─────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ─────────────────────────────────────────
# TypeScript
# ─────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─────────────────────────────────────────
# Cache / Temporary
# ─────────────────────────────────────────
.cache/
.parcel-cache/
.temp/
.tmp/
*.tmp
*.temp

# ─────────────────────────────────────────
# Misc
# ─────────────────────────────────────────
*.pem
*.cert
*.key
*.crt

# Local development
*.local

# Storybook (if used)
storybook-static

# Cypress / Playwright (if used)
cypress/videos/
cypress/screenshots/
/test-results/
/playwright-report/
/playwright/.cache/

# PWA / Service Worker (auto-generated)
**/public/sw.js
**/public/workbox-*.js
**/public/worker-*.js
**/public/sw.js.map
**/public/workbox-*.js.map
**/public/worker-*.js.map

# Bundle analyzer
/analyze/

# Prisma generated client
src/generated/

# Database (if using local sqlite)
*.db
*.sqlite
*.sqlite3
