generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum GuestbookStatus {
  PENDING
  APPROVED
  REJECTED
}

model GuestbookEntry {
  id         String          @id @default(uuid())
  message    String          @db.VarChar(500)
  name       String          @db.VarChar(50)
  email      String?         @db.VarChar(255)
  image      String?         @db.VarChar(500)
  isVerified Boolean         @default(false)
  status     GuestbookStatus @default(PENDING)
  userId     String?         @db.VarChar(255)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([createdAt])
  @@index([status])
}

model UserProfile {
  id                String   @id
  userId            String   @unique @db.VarChar(255)
  discordId         String?  @db.VarChar(255)
  username          String?  @db.VarChar(100)
  displayName       String?  @db.VarChar(100)
  globalName        String?  @db.VarChar(100)
  avatar            String?  @db.VarChar(500)
  banner            String?  @db.VarChar(500)
  bannerColor       String?  @db.VarChar(10)
  bio               String?  @db.VarChar(500)
  accentColor       Int?
  premiumType       Int?
  publicFlags       Int?
  locale            String?  @db.VarChar(10)

  // Discord Primary Guild / Server Tag
  identityGuildId   String?  @db.VarChar(255) @map("identity_guild_id")
  identityEnabled   Boolean? @map("identity_enabled")
  tag               String?  @db.VarChar(4)
  badge             String?  @db.VarChar(100)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([discordId])
  @@index([identityGuildId])
}

// Better Auth tables
model User {
  id            String    @id
  name          String?
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]

  @@map("user")
}

model Account {
  id                   String    @id
  userId               String
  providerId           String
  accountId            String
  accessToken          String?
  refreshToken           String?
  accessTokenExpiresAt   DateTime?
  refreshTokenExpiresAt  DateTime?
  scope                String?
  idToken              String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
