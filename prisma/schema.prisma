generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum GuestbookStatus {
  PENDING
  APPROVED
  REJECTED
}

model GuestbookEntry {
  id         String          @id @default(uuid())
  message    String          @db.VarChar(500)
  name       String          @db.VarChar(50)
  email      String?         @db.VarChar(255)
  image      String?         @db.VarChar(500)
  isVerified Boolean         @default(false)
  status     GuestbookStatus @default(PENDING)
  userId     String?         @db.VarChar(255)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([createdAt])
  @@index([status])
}

model UserProfile {
  id                String   @id
  userId            String   @unique @db.VarChar(255)
  discordId         String?  @db.VarChar(255)
  username          String?  @db.VarChar(100)
  displayName       String?  @db.VarChar(100)
  globalName        String?  @db.VarChar(100)
  avatar            String?  @db.VarChar(500)
  banner            String?  @db.VarChar(500)
  bannerColor       String?  @db.VarChar(10)
  bio               String?  @db.VarChar(500)
  accentColor       Int?
  premiumType       Int?
  publicFlags       Int?
  locale            String?  @db.VarChar(10)
  
  // Discord Primary Guild / Server Tag
  identityGuildId   String?  @db.VarChar(255) @map("identity_guild_id")
  identityEnabled   Boolean? @map("identity_enabled")
  tag               String?  @db.VarChar(4)
  badge             String?  @db.VarChar(100)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([discordId])
  @@index([identityGuildId])
}
